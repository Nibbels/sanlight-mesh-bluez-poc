{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Nibbels/sanlight-mesh-mqtt-gateway/main/schemas/gateway-info-v1.schema.json",
  "title": "SANlight Mesh gateway info v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protocolVersion",
    "serviceVersion",
    "gatewayId",
    "meshUuid",
    "senderAddress",
    "nodes",
    "writePolicy",
    "timestamp"
  ],
  "properties": {
    "protocolVersion": {
      "const": 1
    },
    "serviceVersion": {
      "type": "string",
      "minLength": 1
    },
    "gatewayId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{0,47}$"
    },
    "meshUuid": {
      "type": "string",
      "minLength": 1
    },
    "senderAddress": {
      "type": "string",
      "pattern": "^[0-9A-F]{4}$"
    },
    "commandTopic": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "address",
          "name"
        ],
        "properties": {
          "address": {
            "type": "string",
            "pattern": "^[0-9A-F]{4}$"
          },
          "name": {
            "type": "string"
          }
        }
      }
    },
    "writePolicy": {
      "type": "object"
    },
    "sequenceNumber": {
      "type": "integer",
      "minimum": 0,
      "maximum": 16777215
    },
    "sequenceRemaining": {
      "type": "integer",
      "minimum": 0,
      "maximum": 16777215
    },
    "sequenceRemainingPercent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "sequenceStatus": {
      "enum": [
        "ok",
        "warning",
        "critical"
      ]
    },
    "sequenceWarning": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
