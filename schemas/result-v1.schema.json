{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Nibbels/sanlight-mesh-bluez-poc/schemas/result-v1.schema.json",
  "title": "SANlight Mesh gateway result v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["protocolVersion", "id", "ok", "status", "message", "timestamp"],
  "properties": {
    "protocolVersion": {"const": 1},
    "id": {"type": "string"},
    "ok": {"type": "boolean"},
    "status": {"type": "string"},
    "message": {"type": "string"},
    "action": {"type": "string"},
    "target": {"type": "string"},
    "requested": {"type": "integer"},
    "details": {"type": "object"},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}
