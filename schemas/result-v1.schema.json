{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Nibbels/sanlight-mesh-mqtt-gateway/main/schemas/result-v1.schema.json",
  "title": "SANlight Mesh gateway result v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protocolVersion",
    "id",
    "ok",
    "status",
    "message",
    "timestamp"
  ],
  "properties": {
    "protocolVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "ok": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "action": {
      "enum": [
        "set-max",
        "refresh",
        "read-daylight",
        "blackout",
        "restore-blackout",
        "sync-clock",
        "set-clock",
        "refresh-gateway-info"
      ]
    },
    "target": {
      "type": "string"
    },
    "requested": {
      "type": "integer"
    },
    "requestedSecondsSinceMidnight": {
      "type": "integer",
      "minimum": 0,
      "maximum": 86399
    },
    "details": {
      "type": "object"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}
