{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Nibbels/sanlight-mesh-mqtt-gateway/main/schemas/node-state-v1.schema.json",
  "title": "SANlight Mesh verified node state v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "protocolVersion",
    "address",
    "name",
    "maxBrightness",
    "off",
    "verified",
    "verifiedAt",
    "liveVerified"
  ],
  "properties": {
    "protocolVersion": {
      "const": 1
    },
    "address": {
      "type": "string",
      "pattern": "^[0-9A-F]{4}$"
    },
    "name": {
      "type": "string"
    },
    "maxBrightness": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "off": {
      "type": "boolean"
    },
    "verified": {
      "const": true
    },
    "verifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "cached": {
      "type": "boolean"
    },
    "liveVerified": {
      "type": "boolean"
    },
    "lampClockSeconds": {
      "type": "integer",
      "minimum": 0,
      "maximum": 86399
    },
    "lampClock": {
      "type": "string",
      "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]$"
    },
    "liveBrightnessRaw": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "liveBrightnessPercentEstimate": {
      "type": "number",
      "minimum": 0,
      "maximum": 6553.5
    },
    "liveVerifiedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "liveVerified": {
            "const": true
          }
        },
        "required": [
          "liveVerified"
        ]
      },
      "then": {
        "required": [
          "lampClockSeconds",
          "lampClock",
          "liveBrightnessRaw",
          "liveBrightnessPercentEstimate",
          "liveVerifiedAt"
        ]
      },
      "else": {
        "not": {
          "anyOf": [
            {
              "required": [
                "lampClockSeconds"
              ]
            },
            {
              "required": [
                "lampClock"
              ]
            },
            {
              "required": [
                "liveBrightnessRaw"
              ]
            },
            {
              "required": [
                "liveBrightnessPercentEstimate"
              ]
            },
            {
              "required": [
                "liveVerifiedAt"
              ]
            }
          ]
        }
      }
    }
  ]
}
