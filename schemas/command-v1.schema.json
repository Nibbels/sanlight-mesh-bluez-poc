{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/Nibbels/sanlight-mesh-mqtt-gateway/main/schemas/command-v1.schema.json",
  "title": "SANlight Mesh gateway command v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "action",
    "createdAt",
    "ttlSeconds"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "action": {
      "enum": [
        "set-max",
        "refresh",
        "blackout",
        "restore-blackout"
      ]
    },
    "target": {
      "type": "string"
    },
    "value": {
      "type": "integer"
    },
    "confirmed": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "ttlSeconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "action": {
            "const": "set-max"
          }
        }
      },
      "then": {
        "required": [
          "target",
          "value"
        ],
        "not": {
          "required": [
            "confirmed"
          ]
        },
        "properties": {
          "target": {
            "pattern": "^[0-9A-Fa-f]{4}$"
          },
          "value": {
            "minimum": 20,
            "maximum": 100
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "refresh"
          }
        }
      },
      "then": {
        "not": {
          "anyOf": [
            {
              "required": [
                "value"
              ]
            },
            {
              "required": [
                "confirmed"
              ]
            }
          ]
        },
        "properties": {
          "target": {
            "pattern": "^(all|[0-9A-Fa-f]{4})$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "blackout"
          }
        }
      },
      "then": {
        "required": [
          "target",
          "confirmed"
        ],
        "not": {
          "required": [
            "value"
          ]
        },
        "properties": {
          "target": {
            "pattern": "^(all|[0-9A-Fa-f]{4})$"
          },
          "confirmed": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "action": {
            "const": "restore-blackout"
          }
        }
      },
      "then": {
        "required": [
          "confirmed"
        ],
        "not": {
          "required": [
            "value"
          ]
        },
        "properties": {
          "target": {
            "const": "latest"
          },
          "confirmed": {
            "const": true
          }
        }
      }
    }
  ]
}
