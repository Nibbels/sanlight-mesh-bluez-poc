# The normal installer generates /etc/sanlight-mesh-mqtt-gateway/gateway.toml.
# This file is an advanced manual-reference example only.
# Never place MQTT passwords directly in TOML; use password_file.

[gateway]
id = "sanlight-pi"
project_root = ".."
cdb = "SANlightMesh.json"
state_dir = "../.state"
control_app_id = 1
sender_app_id = 2
command_timeout_seconds = 45
queue_max_size = 32
dedup_ttl_seconds = 86400
dedup_max_entries = 512
coalesce_window_seconds = 2.0
# 0 disables cache-only write suppression. Enable only when the gateway is the sole writer.
state_fresh_seconds = 0
refresh_on_start = true
# Set to 0 to disable periodic refresh. Polling consumes Mesh Sequence Numbers.
refresh_interval_seconds = 1800

[mqtt]
# The normal product topology runs Mosquitto on this same gateway Pi.
host = "127.0.0.1"
port = 1883
topic_prefix = "sanlightmesh/v1"
client_id = "sanlightmesh-sanlight-pi"
keepalive_seconds = 60
qos = 1
username = "sanlight-gateway-sanlight-pi"
password_file = "/etc/sanlight-mesh-mqtt-gateway/mqtt-password.txt"
tls = false
